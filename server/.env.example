PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/vedaai
REDIS_URL=redis://127.0.0.1:6379

# Primary LLM — Google Gemini (https://aistudio.google.com/apikey)
# Key must start with AIza... (AI Studio). Restart server after changing .env.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Tried in order if primary model hits quota (comma-separated)
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash-lite,gemini-1.5-flash

# Optional fallback LLM (same JSON output contract)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

SCHOOL_NAME=Delhi Public School, Sector-4, Bokaro
DEFAULT_SUBJECT=Science
DEFAULT_CLASS=8th
